  "keyFeatures": [
    "Record blood pressure measurements three times per period (Morning, Afternoon, Night)",
    "Calendar heatmap visualization showing daily averages with color-coded indicators",
    "Detailed day view with period-based grouping and blood pressure classification",
    "Smart notification reminders using WorkManager for missed measurements",
    "Local data persistence with Room database",
    "Multi-language support (Spanish, English, Galician)"
  ],
  "publicApiSurface": [
    "Medicion (data class with sistolica, diastolica, timestamp)",
    "MedicionDao (Room DAO for database operations)",
    "MedicionRepository (data layer abstraction)",
    "MedicionViewModel (handles measurement screen logic)",
    "CalendarioViewModel (manages calendar state)",
    "DiaDetalleViewModel (day detail screen logic)",
    "EstadoTension (blood pressure classification enum)",
    "PeriodoDelDia (day period enum: Morning, Afternoon, Night)",
    "ReminderWorker (WorkManager notification worker)"
  ]
}
